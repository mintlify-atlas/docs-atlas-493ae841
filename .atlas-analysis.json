  "keyFeatures": [
    "Browser-based IDE with multi-file editing and file tree",
    "Integrated AI assistant with 30+ tool/function actions",
    "BYOK (bring-your-own-key) support for OpenAI, Anthropic, Gemini, Perplexity, DeepSeek, xAI, Cohere, and OpenRouter",
    "Browser-native shell via WebContainers (Node.js runtime)",
    "Workflow automation — create, save, and run reusable workflows",
    "Git integration (commit, branch, import from GitHub/GitLab)",
    "Media generation: images, music/audio, and 3D models",
    "Arduino firmware compilation and WebSerial upload",
    "Scratch block programming environment",
    "Collaborative editing and project sharing with subdomain publishing",
    "Theme system with custom theme creator and library",
    "Supabase Auth + Edge Functions backend"
  ],
